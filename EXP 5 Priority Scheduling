#include<stdio.h>

struct process
{
    int bt, pr, wt, tat;
}p[10];

int main()
{
    int n,i,j;
    struct process temp;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        printf("Enter Burst Time and Priority: ");
        scanf("%d%d",&p[i].bt,&p[i].pr);
    }

    for(i=0;i<n;i++)
    {
        for(j=i+1;j<n;j++)
        {
            if(p[i].pr < p[j].pr)
            {
                temp=p[i];
                p[i]=p[j];
                p[j]=temp;
            }
        }
    }

    p[0].wt=0;

    for(i=1;i<n;i++)
    {
        p[i].wt=p[i-1].wt+p[i-1].bt;
    }

    printf("\nBT\tPriority\tWT\tTAT\n");

    for(i=0;i<n;i++)
    {
        p[i].tat=p[i].wt+p[i].bt;
        printf("%d\t%d\t\t%d\t%d\n",
               p[i].bt,p[i].pr,p[i].wt,p[i].tat);
    }

    return 0;
}
