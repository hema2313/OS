#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>

int main()
{
    pid_t pid;

    pid = fork();   // Create a new process

    if (pid < 0)
    {
        printf("Process creation failed.\n");
    }
    else if (pid == 0)
    {
        // Child Process
        printf("\nChild Process\n");
        printf("PID  = %d\n", getpid());
        printf("PPID = %d\n", getppid());
    }
    else
    {
        // Parent Process
        printf("\nParent Process\n");
        printf("PID  = %d\n", getpid());
        printf("PPID = %d\n", getppid());
    }

    return 0;
}
