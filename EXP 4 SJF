#include<stdio.h>

int main()
{
    int bt[20], p[20], wt[20], tat[20];
    int n,i,j,temp,pos;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        printf("Enter Burst Time of P%d: ",i+1);
        scanf("%d",&bt[i]);
        p[i]=i+1;
    }

    for(i=0;i<n;i++)
    {
        pos=i;

        for(j=i+1;j<n;j++)
        {
            if(bt[j]<bt[pos])
                pos=j;
        }

        temp=bt[i];
        bt[i]=bt[pos];
        bt[pos]=temp;

        temp=p[i];
        p[i]=p[pos];
        p[pos]=temp;
    }

    wt[0]=0;

    for(i=1;i<n;i++)
    {
        wt[i]=wt[i-1]+bt[i-1];
    }

    printf("\nProcess\tBT\tWT\tTAT\n");

    for(i=0;i<n;i++)
    {
        tat[i]=bt[i]+wt[i];
        printf("P%d\t%d\t%d\t%d\n",
               p[i],bt[i],wt[i],tat[i]);
    }

    return 0;
}
